# Core Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver,insightloop.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://insightloop.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB
# Local MongoDB example:
# MONGODB_URI=mongodb://localhost:27017/InsightLoop
#
# MongoDB Atlas development example using a standard connection string
# instead of mongodb+srv to avoid SRV/DNS startup delays:
# MONGODB_URI=mongodb://<USERNAME>:<URL_ENCODED_PASSWORD>@host1:27017,host2:27017,host3:27017/InsightLoop?tls=true&authSource=admin&replicaSet=<replica-set>&retryWrites=true&w=majority&appName=InsightLoop&serverSelectionTimeoutMS=5000&connectTimeoutMS=5000&socketTimeoutMS=5000
MONGODB_URI=mongodb://localhost:27017/InsightLoop
MONGODB_DB_NAME=InsightLoop
MONGODB_CONNECT_ON_INIT=false

# Redis / Channels
REDIS_URL=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
ADMIN_EMAIL=admin@example.com

# OAuth / Social Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback/

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback/

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback/

# Optional S3 / media storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
